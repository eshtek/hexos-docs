{
  "version": 3,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial Script"
  },
  "requirements": {
    "locations": [
      "Documents",
      "Downloads"
    ],
    "specifications": [
      "2CORE", "1024MB"],
    "permissions": [
      "READ_WRITE_LOCATIONS"
    ],
    "ports": [30289]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(Downloads)",
      "network_share": true
    },
    {
      "path": "$LOCATION(Documents)",
      "network_share": true
    },
    "$LOCATION(Documents)/PDFs"
  ],
  "app_values": {
    "storage": {
      "additional_storage": [
        "$MOUNTED_HOST_PATH($LOCATION(Documents)/PDFs, /PDFs)",
        "$MOUNTED_HOST_PATH($LOCATION(Downloads), /downloads)"
      ]
    },
    "network": {
      "web_port": {
        "port_number": 30289
      }
    },
    "resources": {
      "limits": {
        "cpus": 4,
        "memory": "$MEMORY(5%, 1024)"
      }
    }
  }
}
