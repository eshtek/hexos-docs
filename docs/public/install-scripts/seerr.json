{
  "version": 3,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial Script"
  },
  "requirements": {
    "locations": [
      "ApplicationsPerformance"
    ],
    "specifications": [
      "2CORE",
      "1024MB"
    ],
    "permissions": [
      "READ_WRITE_LOCATIONS"
    ],
    "ports": [30357]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(ApplicationsPerformance)",
      "network_share": true
    },
    "$LOCATION(ApplicationsPerformance)/seerr/config"
  ],
  "app_values": {
    "storage": {
      "config": "$HOST_PATH($LOCATION(ApplicationsPerformance)/seerr/config)"
    },
    "network": {
      "web_port": {
        "bind_mode": "published",
        "port_number": 30357
      }
    },
    "resources": {
      "limits": {
        "cpus": 2,
        "memory": "$MEMORY(10%, 2048)"
      }
    }
  }
}