{
  "version": 4,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial script"
  },
  "requirements": {
    "locations": ["ApplicationsPerformance"],
    "specifications": ["2CORE", "200MB"],
    "permissions": ["READ_WRITE_LOCATIONS"],
    "ports": [30267]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(ApplicationsPerformance)",
      "network_share": true
    },
    {"path": "$LOCATION(ApplicationsPerformance)/nevu/data", "owner": { "user": "apps" }, "snapshot": { "id": "data" } }
  ],
  "app_values": {
    "nevu": {
      "plex_server": "http://$SERVER_LAN_IP:32400"
    },
    "storage": {
      "data": "$HOST_PATH($LOCATION(ApplicationsPerformance)/nevu/data)"
    },
  "network": {
    "web_port": {
      "bind_mode": "published",
      "port_number": 30267
    }
  },
    "resources": {
      "limits": {
        "cpus": 2,
        "memory": "$MEMORY(10%, 2048)"
      }
    }
  }
}