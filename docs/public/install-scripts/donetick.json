{
  "version": 4,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial"
  },
  "requirements": {
    "locations": ["ApplicationsPerformance"],
    "specifications": ["2CORE", "256MB"],
    "permissions": ["READ_WRITE_LOCATIONS"],
    "ports": [30353]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(ApplicationsPerformance)",
      "network_share": true
    },
    { "path": "$LOCATION(ApplicationsPerformance)/donetick/data", "owner": { "user": "apps" }, "snapshot": { "id": "data" } },
    { "path": "$LOCATION(ApplicationsPerformance)/doentick/config", "owner": { "user": "apps" }, "snapshot": { "id": "config" } }
  ],
  "app_values": {
    "donetick": {
      "jwt_secret": "$RANDOM_STRING(32)"
    },
    "network": {
      "web_port": {
        "bind_mode": "published",
        "port_number": 30353
      }
    },
    "storage": {
      "data": "$HOST_PATH($LOCATION(ApplicationsPerformance)/donetick/data)",
      "config": "$HOST_PATH($LOCATION(ApplicationsPerformance)/donetick/config)"
    },
    "resources": {
      "limits": {
        "cpus": 2,
        "memory": "$MEMORY(10%, 4096)"
      }
    }
  }
}