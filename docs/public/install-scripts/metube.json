{
  "version": 3,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial script"
  },
  "requirements": {
    "locations": ["ApplicationsCapacity", "Downloads"],
    "specifications": ["2CORE", "200MB"],
    "permissions": ["READ_WRITE_LOCATIONS"],
    "ports": [30094]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(ApplicationsCapacity)",
      "network_share": true
    },
    {
      "path": "$LOCATION(Downloads)",
      "network_share": true
    },
    "$LOCATION(Downloads)/metube"
  ],
  "app_values": {
    "storage": {
      "downloads": "$HOST_PATH($LOCATION(Downloads)/metube)"
    },
    "network": {
      "web_port": {
        "bind_mode": "published",
        "port_number": 30094
      }
    },
    "resources": {
      "limits": {
        "cpus": 2,
        "memory": "$MEMORY(10%, 2048)"
      }
    }
  }
}