{
  "version": 4,
  "script": {
    "version": "1.0.0",
    "changeLog": "Initial"
  },
  "requirements": {
    "locations": ["ApplicationsPerformance"],
    "specifications": ["2CORE", "256MB"],
    "permissions": ["READ_WRITE_LOCATIONS"],
    "ports": [30106]
  },
  "ensure_directories_exists": [
    {
      "path": "$LOCATION(ApplicationsPerformance)",
      "network_share": true
    },
    { "path": "$LOCATION(ApplicationsPerformance)/joplin/postgres_data", "owner": { "user": "netdata", "group": "docker" }, "snapshot": { "id": "db" } }
  ],
  "app_values": {
    "joplin": {
      "db_password": "$RANDOM_STRING(7)",
      "base_url": "http://$SERVER_LAN_IP:30106",
      "additional_envs": []
    },
    "network": {
      "web_port": {
        "bind_mode": "published",
        "port_number": 30106
      }
    },
    "storage": {
      "postgres_data": "$HOST_PATH($LOCATION(ApplicationsPerformance)/joplin/postgres_data)"
    },
    "resources": {
      "limits": {
        "cpus": 2,
        "memory": "$MEMORY(10%, 4096)"
      }
    }
  }
}